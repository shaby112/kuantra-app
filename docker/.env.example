INSIGHTOPS_PORT=8080
DB_PASSWORD=change-this

# Auth mode: "dev" (no token needed), "license" (HMAC JWT), "jwks" (external IdP)
AUTH_MODE=dev
AUTH_SECRET_KEY=          # required when AUTH_MODE=license (HMAC HS256 secret)
AUTH_ISSUER=              # optional JWT issuer claim
AUTH_JWKS_URL=            # required when AUTH_MODE=jwks
VITE_AUTH_MODE=license

# Optional server-side fallback for LLM requests.
# Users can also provide per-browser keys in the app Settings page.
GOOGLE_API_KEY=

# Required for encrypting stored connection credentials
ENCRYPTION_KEY=

# Optional runtime tuning
LLM_MODEL=gemini-2.0-flash

# Local LLM (not bundled in Docker image; user downloads model on demand)
AI_PROVIDER=gemini
ALLOW_CLOUD_LLM=true
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434
LOCAL_LLM_MODEL=qwen3.5:4b
LOCAL_LLM_API_KEY=
LOCAL_LLM_AUTO_PULL=false

DUCKDB_MEMORY_LIMIT=4GB
DUCKDB_THREADS=4
CORS_ORIGINS=
UVICORN_WORKERS=1
UVICORN_LOG_LEVEL=info
RUN_MIGRATIONS_ON_START=true
